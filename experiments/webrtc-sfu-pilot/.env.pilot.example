# 复制为 .env 后按需填写（本目录: cp .env.pilot.example .env）
# 不要写 PILOT_VERSION / MEDIASOUP_INGEST_CODEC，除非你要故意覆盖 docker-compose.yml 的默认值；
# 否则易出现「仓库已 bump 到 p，curl 仍是 m」或「想测 h264 容器却一直是 vp8」。

MEDIASOUP_ANNOUNCED_IP=你的浏览器可达IP或EIP
MEDIASOUP_INGEST_TEST=1
# 整条 C1 先跑通 H264 时建议显式写上（避免旧 .env 里曾留 vp8）：
MEDIASOUP_INGEST_CODEC=h264
# 可选：Router 只注册 H264，彻底杜绝浏览器协商到 VP8 ingest 混用
# MEDIASOUP_ROUTER_VIDEO_H264_ONLY=1

# 可选排查
# MEDIASOUP_WORKER_DEBUG=1
