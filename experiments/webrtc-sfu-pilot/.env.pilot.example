# 复制为 .env 后按需填写（本目录: cp .env.pilot.example .env）
# 不要写 PILOT_VERSION / MEDIASOUP_INGEST_CODEC，除非你要故意覆盖 docker-compose.yml 的默认值；
# 否则易出现「仓库已 bump 到 p，curl 仍是 m」或「想测 h264 容器却一直是 vp8」。

# PoC ARM ECS 公网 EIP（与本仓库文档一致；其它环境请改）
MEDIASOUP_ANNOUNCED_IP=8.166.118.148
MEDIASOUP_INGEST_TEST=1
# 整条 C1 先跑通 H264 时建议显式写上（避免旧 .env 里曾留 vp8）：
MEDIASOUP_INGEST_CODEC=h264
# 可选：Router 只注册 H264，彻底杜绝浏览器协商到 VP8 ingest 混用
# MEDIASOUP_ROUTER_VIDEO_H264_ONLY=1
# VP8/FFmpeg 出现 bytesReceived 大但 rtpBytesReceived=0 时，试与 mediasoup-demo 一致的分流 RTCP：
# MEDIASOUP_INGEST_RTCP_MUX=0

# 可选排查
# MEDIASOUP_WORKER_DEBUG=1

# --- Layer C2（触控回注；须 docker compose build 含 adb）---
# PILOT_C2_ENABLED=1
# C2_ADB_SERIAL=127.0.0.1:5555
# C2_DEVICE_WIDTH=720
# C2_DEVICE_HEIGHT=1280
# PILOT_C2_MAX_PER_MIN=120
# 公网务必随机强口令：
# PILOT_C2_TOKEN=
