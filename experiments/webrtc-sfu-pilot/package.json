{
  "name": "webrtc-sfu-pilot",
  "private": true,
  "description": "mediasoup SFU pilot: Layer A+B + optional C1 PlainTransport ingest (FFmpeg)",
  "pilotVersion": "pilot-20260516c2pointer",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prestart": "npm run build:client",
    "start": "node server.cjs",
    "build:client": "node scripts/sync-pilot-version.cjs && esbuild client/entry.mjs --bundle --format=esm --outfile=public/mediasoup-client.esm.js --platform=browser",
    "c1:ingest": "bash scripts/run-c1-ffmpeg-ingest.sh",
    "c1:ingest:adb": "env C1_INGEST_SOURCE=adb bash scripts/run-c1-ffmpeg-ingest.sh",
    "c1:ingest:adb:loop": "bash scripts/run-c1-ingest-adb-loop.sh",
    "c1:check:adb": "bash scripts/check-c1-adb-prereqs.sh",
    "c1:diagnose:adb": "bash scripts/diagnose-adb-screenrecord.sh",
    "adb:dismiss-log-dialog": "bash scripts/adb-dismiss-log-access-dialog.sh",
    "adb:start-zhangting-dismiss-log-dialog": "bash scripts/adb-dismiss-log-access-dialog.sh --start-zhangting",
    "adb:capture-auth-debug": "bash scripts/adb-capture-screen-ui-for-auth.sh",
    "pilot:ingest-debug": "bash scripts/pilot-ingest-debug.sh",
    "c1:streaming:check": "bash scripts/c1-streaming-phased-check.sh",
    "c1:diag:sfu": "bash scripts/c1-sfu-stats-after-viewer.sh",
    "c1:diag:sfu:last": "bash scripts/c1-sfu-stats-after-viewer.sh --last-consume",
    "c1:diag:ingest": "bash scripts/c1-ingest-checklist.sh",
    "c1:check:comedia": "bash scripts/c1-ingest-comedia-check.sh",
    "c1:safe:stop": "bash scripts/c1-ingest-safe.sh stop",
    "c1:safe:status": "bash scripts/c1-ingest-safe.sh status",
    "c1:safe:pilot-recreate": "bash scripts/c1-ingest-safe.sh pilot-recreate",
    "c1:safe:colorbar": "bash scripts/c1-ingest-safe.sh colorbar",
    "c1:safe:adb": "bash scripts/c1-ingest-safe.sh adb",
    "c2:smoke": "bash scripts/c2-smoke.sh",
    "c1:yundian:push+c2": "bash scripts/c1-restart-yundian-push-and-c2-smoke.sh",
    "c1:yundian:full": "PILOT_UP=1 bash scripts/c1-restart-yundian-push-and-c2-smoke.sh",
    "c1:ingest:adb:short": "env SCREENRECORD_TIME_LIMIT=20 C1_INGEST_SOURCE=adb bash scripts/run-c1-ffmpeg-ingest.sh --local",
    "c1:ingest:adb:short:v": "env SCREENRECORD_TIME_LIMIT=20 ADB_SCREENRECORD_STDERR=/dev/stderr FFMPEG_LOGLEVEL=info C1_INGEST_SOURCE=adb bash scripts/run-c1-ffmpeg-ingest.sh --local"
  },
  "dependencies": {
    "express": "^4.21.0",
    "mediasoup": "^3.19.22",
    "mediasoup-client": "3.18.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
