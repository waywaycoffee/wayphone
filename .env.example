# 复制为 .env 后按需修改（可选；不设则用 compose 内默认值）
# cp .env.example .env

# ---------- Redroid（docker-compose.yml）----------
REDROID_IMAGE=redroid/redroid:13.0.0-64only-latest
REDROID_HOST_PORT=5555

# ---------- docker-android（docker-compose.emulator.yml）----------
DOCKER_ANDROID_IMAGE=budtmo/docker-android:emulator_11.0
EMULATOR_WEB_PORT=6080
EMULATOR_DEVICE=Samsung Galaxy S10

# ---------- 一键部署脚本 ----------
# auto：有 /dev/kvm 则起 docker-android，否则 Redroid
# redroid | emulator：强制模式
DEPLOY_MODE=auto
